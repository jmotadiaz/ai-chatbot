{
  "name": "ai-sdk-starter",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "rag-mcp-chatbot": "./mcp-server/index.ts"
  },
  "scripts": {
    "dev": "npm run db:start && next dev",
    "build": "npx tsx lib/infrastructure/db/migrate.ts && next build",
    "preview": "dotenv -e .env.development.local -- sh -c 'npm run db:start && npm run build && next start -p 8085'",
    "agent:start": "export NEXT_PUBLIC_ENV=test && npm run db:test:start && npm run db:migrate && npm run db:seed && NODE_ENV=test npx next dev",
    "jules:start": "export NEXT_PUBLIC_ENV=test && npm run db:jules:start && npm run db:migrate && npm run db:seed && NODE_ENV=test npx next dev",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "npx tsx lib/infrastructure/db/migrate.ts",
    "db:seed": "npx tsx scripts/seed-test-data.ts",
    "db:start": "docker compose up -d --wait",
    "db:stop": "docker compose down",
    "db:test:start": "docker compose -f docker-compose.test.yml up --wait",
    "db:test:stop": "docker compose  -f docker-compose.test.yml down",
    "db:jules:start": "sudo docker compose -f docker-compose.test.yml up --wait",
    "db:jules:stop": "sudo docker compose  -f docker-compose.test.yml down",
    "db:logs": "docker-compose logs -f",
    "lint": "eslint . && npm run type:check",
    "lint:fix": "eslint --fix . && npm run type:check",
    "type:check": "tsc --noEmit",
    "test": "npm run test:e2e",
    "test:e2e": "npm run db:test:start && trap 'npm run db:test:stop' EXIT && playwright test $PLAYWRIGHT_ARGS",
    "test:e2e:ui": "npm run db:test:start && trap 'npm run db:test:stop' EXIT && playwright test --ui $PLAYWRIGHT_ARGS",
    "test:e2e:headed": "npm run db:test:start && trap 'npm run db:test:stop' EXIT && playwright test --headed $PLAYWRIGHT_ARGS",
    "test:e2e:jules": "npm run db:jules:stop && npm run db:jules:start && playwright test",
    "mcp:start": "npm run mcp-server",
    "mcp-server": "dotenv -e .env.development.local -- tsx --tsconfig mcp-server/tsconfig.json mcp-server/index.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.15",
    "@ai-sdk/cohere": "^3.0.18",
    "@ai-sdk/deepseek": "2.0.8",
    "@ai-sdk/gateway": "3.0.16",
    "@ai-sdk/google": "3.0.10",
    "@ai-sdk/groq": "3.0.10",
    "@ai-sdk/openai": "3.0.12",
    "@ai-sdk/openai-compatible": "^2.0.13",
    "@ai-sdk/perplexity": "3.0.8",
    "@ai-sdk/provider": "^3.0.4",
    "@ai-sdk/provider-utils": "^4.0.8",
    "@ai-sdk/react": "3.0.41",
    "@ai-sdk/xai": "3.0.26",
    "@faker-js/faker": "^8.4.1",
    "@langchain/core": "^1.1.0",
    "@langchain/textsplitters": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@openrouter/ai-sdk-provider": "1.0.0-beta.5",
    "@opentelemetry/api-logs": "^0.200.0",
    "@opentelemetry/instrumentation": "^0.200.0",
    "@opentelemetry/sdk-logs": "^0.200.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.1",
    "@streamdown/code": "^1.0.1",
    "@streamdown/math": "^1.0.1",
    "@streamdown/mermaid": "^1.0.1",
    "@types/turndown": "^5.0.5",
    "@uiw/react-md-editor": "^4.0.7",
    "@vercel/blob": "^2.0.0",
    "@vercel/otel": "^1.10.4",
    "@vercel/postgres": "^0.10.0",
    "add": "^2.0.6",
    "ai": "^6.0.39",
    "bcrypt": "^6.0.0",
    "bcrypt-ts": "^7.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cohere-ai": "^7.20.0",
    "deepmerge": "^4.3.1",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.5",
    "drizzle-orm": "^0.44.6",
    "drizzle-seed": "^0.3.1",
    "exa-js": "^1.8.22",
    "fast-deep-equal": "^3.1.3",
    "jsdom": "^26.1.0",
    "langchain": "^1.1.1",
    "lucide-react": "^0.487.0",
    "marked": "^16.1.1",
    "motion": "^12.6.3",
    "next": "16.1.1",
    "next-auth": "5.0.0-beta.28",
    "next-themes": "^0.4.6",
    "nuqs": "^2.6.0",
    "ollama-ai-provider": "^1.2.0",
    "p-throttle": "^8.0.0",
    "pgvector": "^0.2.1",
    "postgres": "^3.4.5",
    "react": "19.2.1",
    "react-collapsed": "^4.2.0",
    "react-dom": "^19.2.1",
    "react-dropzone": "^14.3.8",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.1",
    "rehype-class-names": "^2.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.3",
    "streamdown": "^2.1.0",
    "tailwind-merge": "^3.2.0",
    "tailwindcss-animate": "^1.0.7",
    "turndown": "^7.2.0",
    "use-debounce": "^10.0.6",
    "usehooks-ts": "^3.1.1",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/mcp": "^0.0.54",
    "@playwright/test": "^1.56.0",
    "@tailwindcss/postcss": "^4.1.3",
    "@types/bcrypt": "^5.0.2",
    "@types/jsdom": "^21.1.7",
    "@types/marked": "^6.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.1",
    "@types/react-dom": "^19.2.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/parser": "^8.35.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.24.0",
    "eslint-config-next": "15.2.4",
    "eslint-config-prettier": "^10.1.2",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-import-x": "^4.15.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "next-devtools-mcp": "^0.3.7",
    "node-loader": "^2.1.0",
    "tailwindcss": "^4.1.3",
    "tsc-files": "^1.1.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
