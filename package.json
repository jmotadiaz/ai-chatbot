{
  "name": "ai-sdk-starter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run db:start && next dev",
    "build": "npx tsx lib/db/migrate.ts && next build",
    "start": "next start",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx lib/db/migrate.ts",
    "db:setup": "./scripts/setup-local-db.sh",
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "db:test:start": "docker compose -f docker-compose.test.yml up -d",
    "db:test:stop": "docker compose  -f docker-compose.test.yml down",
    "db:logs": "docker-compose logs -f",
    "lint": "next lint && tsc --noEmit",
    "lint:fix": "next lint --fix && tsc --noEmit",
    "type:check": "tsc --noEmit",
    "test": "npm run test:e2e",
    "test:e2e": "npm run db:test:start && playwright test && npm run db:test:stop",
    "test:e2e:ui": "npm run db:test:start && playwright test --ui && npm run db:test:stop",
    "test:e2e:headed": "npm run db:test:start && playwright test --headed && npm run db:test:stop",
    "test:e2e:jules": "sudo docker compose  -f docker-compose.test.yml down && sudo docker compose -f docker-compose.test.yml up -d && playwright",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "2.0.22",
    "@ai-sdk/deepseek": "1.0.7",
    "@ai-sdk/google": "2.0.13",
    "@ai-sdk/groq": "2.0.10",
    "@ai-sdk/openai": "2.0.15",
    "@ai-sdk/perplexity": "2.0.8",
    "@ai-sdk/react": "2.0.56",
    "@ai-sdk/xai": "2.0.22",
    "@llamaindex/core": "^0.6.13",
    "@openrouter/ai-sdk-provider": "1.0.0-beta.5",
    "@opentelemetry/api-logs": "^0.200.0",
    "@opentelemetry/instrumentation": "^0.200.0",
    "@opentelemetry/sdk-logs": "^0.200.0",
    "@types/turndown": "^5.0.5",
    "@uiw/react-md-editor": "^4.0.7",
    "@vercel/blob": "^2.0.0",
    "@vercel/otel": "^1.10.4",
    "@vercel/postgres": "^0.10.0",
    "add": "^2.0.6",
    "ai": "5.0.63",
    "bcrypt": "^6.0.0",
    "bcrypt-ts": "^7.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.5",
    "drizzle-orm": "^0.44.6",
    "drizzle-seed": "^0.3.1",
    "exa-js": "^1.8.22",
    "fast-deep-equal": "^3.1.3",
    "jsdom": "^26.1.0",
    "lucide-react": "^0.487.0",
    "marked": "^16.1.1",
    "motion": "^12.6.3",
    "next": "15.5.0",
    "next-auth": "5.0.0-beta.28",
    "next-themes": "^0.4.6",
    "nuqs": "^2.6.0",
    "ollama-ai-provider": "^1.2.0",
    "p-throttle": "^8.0.0",
    "pgvector": "^0.2.1",
    "postgres": "^3.4.5",
    "react": "19.2.0",
    "react-collapsed": "^4.2.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.3.8",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.1",
    "rehype-class-names": "^2.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.3",
    "streamdown": "^1.3.0",
    "tailwind-merge": "^3.2.0",
    "tailwindcss-animate": "^1.0.7",
    "turndown": "^7.2.0",
    "usehooks-ts": "^3.1.1",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.56.0",
    "@tailwindcss/postcss": "^4.1.3",
    "@types/bcrypt": "^5.0.2",
    "@types/jsdom": "^21.1.7",
    "@types/marked": "^6.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "19.2.0",
    "@types/react-dom": "^19.1.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/parser": "^8.35.0",
    "eslint": "^9.24.0",
    "eslint-config-next": "15.2.4",
    "eslint-config-prettier": "^10.1.2",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-import-x": "^4.15.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "tailwindcss": "^4.1.3",
    "tsc-files": "^1.1.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "next lint --fix --file",
      "tsc-files --noEmit"
    ]
  }
}
